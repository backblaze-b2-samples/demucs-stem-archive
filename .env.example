# Backblaze B2 (required)
B2_APPLICATION_KEY_ID=your_key_id
B2_APPLICATION_KEY=your_application_key
B2_BUCKET_NAME=your-bucket-name
B2_REGION=your_region
B2_PUBLIC_URL_BASE=

# The S3 endpoint is derived from B2_REGION as
#   https://s3.<B2_REGION>.backblazeb2.com
# Set B2_ENDPOINT only if you need to override that derived URL explicitly.
# B2_ENDPOINT=

# Example of what filled-in values look like (fake — for visual reference only):
# B2_APPLICATION_KEY_ID=<24-char key id from the B2 console>
# B2_APPLICATION_KEY=<31-char application key, shown once>
# B2_BUCKET_NAME=my-stem-archive
# B2_REGION=us-west-004
# B2_PUBLIC_URL_BASE=https://my-stem-archive.s3.us-west-004.backblazeb2.com
